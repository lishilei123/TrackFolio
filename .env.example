# TrackFolio 环境变量示例
# 复制为 .env 后按需修改。所有变量都有默认值，留空即用默认。
# 加载方式（任选其一）：
#   1) Node 20+ 原生：node --env-file=.env app/server/dist/index.js
#   2) 进程环境变量 / Docker -e / 云平台配置面板
#   3) Docker Compose 的 .env / --env-file 变量插值
# 注意：变量仅供单体服务进程使用；前端 web 无运行时环境变量（API 走 /api 相对路径）。

# ───────────────── 服务 ─────────────────
# 单体应用 HTTP 监听端口（host 固定 0.0.0.0）
PORT=5174
# 前端静态文件目录；生产构建后默认自动定位到 app/web/dist，通常无需设置
# TRACKFOLIO_WEB_ROOT=./app/web/dist
# 日志级别：fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# ─────────────── 数据库（二选一）───────────────
# 默认使用 SQLite（零配置，单机/开发推荐）。数据库文件路径：
TRACKFOLIO_DB=./app/server/data/trackfolio.sqlite

# 切换到 PostgreSQL：设置 DATABASE_URL 即自动启用（或显式 DB_DRIVER=postgres）。
# DB_DRIVER=postgres
# DATABASE_URL=postgres://user:password@localhost:5432/trackfolio
# 连接池大小（仅 PostgreSQL）
# PG_POOL_MAX=10
# 托管数据库需要 SSL 时设为 require（如 Neon / Supabase / RDS）
# PGSSL=require

# ─────────────── 后台安全 ───────────────
# 后台密码连续错误多少次后临时锁定
# TRACKFOLIO_ADMIN_MAX_FAILED_ATTEMPTS=5
# 后台密码错误过多后的锁定分钟数
# TRACKFOLIO_ADMIN_LOCK_MINUTES=15

# ─────────────── 行情数据源 ───────────────
# 股票/基金行情：auto（默认，自动择源）| sina | yahoo
TRACKFOLIO_PROVIDER=auto
# 汇率源：auto（默认）| exchangerate | yahoo | mock
# 不设置时跟随后台「显示设置」里的选择
# TRACKFOLIO_FX_PROVIDER=auto
