# TrackFolio 环境变量示例
# 复制为 .env 后按需修改。所有变量都有默认值，留空即用默认。
# 加载方式（任选其一）：
#   1) Node 22+ 原生：node --env-file=.env app/server/dist/index.js
#   2) 进程环境变量 / Docker -e / 云平台配置面板
#   3) Docker Run --env-file / 云平台配置面板
# 注意：变量仅供单体服务进程使用；前端 web 无运行时环境变量（API 走 /api 相对路径）。

# ───────────────── 服务 ─────────────────
# 单体应用 HTTP 监听端口（host 固定 0.0.0.0）
PORT=5174
# 日志级别：fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# ─────────────── 数据库（二选一）───────────────
# 默认使用 SQLite（零配置，单机/开发推荐）。数据库文件路径：
TRACKFOLIO_DB=./app/server/data/trackfolio.sqlite

# 切换到 PostgreSQL：设置 DATABASE_URL 即自动启用。
# DATABASE_URL=postgres://user:password@localhost:5432/trackfolio
# 托管数据库需要 SSL 时，在连接串里加 sslmode（如 Neon / Supabase / RDS）：
# DATABASE_URL=postgres://user:password@host:5432/trackfolio?sslmode=require

# ─────────────── 后台安全 ───────────────
# 初始后台密码；仅首次初始化数据库或既有库缺少密码 hash 时生效。公网部署请设为强密码。
# TRACKFOLIO_ADMIN_PASSWORD=change-this-password
# 后台密码连续错误多少次后临时锁定
# TRACKFOLIO_ADMIN_MAX_FAILED_ATTEMPTS=5
# 后台密码错误过多后的锁定分钟数
# TRACKFOLIO_ADMIN_LOCK_MINUTES=15

# ─────────────── 数据源设置 ───────────────
# 股票/基金行情源固定为自动源；汇率源可在后台「显示设置」里选择，默认 auto。
