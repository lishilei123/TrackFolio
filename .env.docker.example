# Docker Compose variables.
# Use one of:
#   docker compose --env-file .env.docker up --build -d
#   or copy this file to .env, which Docker Compose reads automatically.

# Single image name used by Docker Compose.
TRACKFOLIO_IMAGE=trackfolio:local

# Web access port on the host.
TRACKFOLIO_HTTP_PORT=8080

# Backend log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Initial admin password; only used when the database is initialized for the first time.
TRACKFOLIO_ADMIN_PASSWORD=change-this-password

# Used only with:
#   docker compose -f compose.yaml -f compose.postgres.yaml up --build -d
TRACKFOLIO_POSTGRES_PASSWORD=change-me
