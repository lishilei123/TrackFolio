# TrackFolio Docker runtime variables.
# Copy to .env.docker and pass it to Docker Run with:
#   docker run ... --env-file .env.docker ghcr.io/lishilei123/trackfolio:latest

# Backend log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# SQLite database path inside the container. Keep this under /data when mounting a data volume.
TRACKFOLIO_DB=/data/trackfolio.sqlite

# Initial admin password; only used when the database is initialized for the first time.
TRACKFOLIO_ADMIN_PASSWORD=change-this-password

# Optional PostgreSQL mode. Uncomment and point to your PostgreSQL service to use it instead of SQLite.
# DATABASE_URL=postgres://trackfolio:change-me@trackfolio-postgres:5432/trackfolio
# If the database requires SSL, add sslmode to the connection string, e.g.:
# DATABASE_URL=postgres://trackfolio:change-me@host:5432/trackfolio?sslmode=require
